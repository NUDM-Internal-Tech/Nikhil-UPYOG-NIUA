{
  "moduleName": "cnd_vendor_module",
  "description": "CnD vendor full workflow",

  "baseUrl": "${selected.url}",

  "instructions": [

    {
      "stepName": "Open CnD Module",
      "locatorStrategy": "XPATH",
      "locatorValue": "//a[@href='/cnd-ui/citizen/cnd-home']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 2000
    },

    {
      "stepName": "Open Vendor Module",
      "locatorStrategy": "XPATH",
      "locatorValue": "//a[@href='/cnd-ui/citizen/cnd/cnd-vendor']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 2000
    },

    {
      "stepName": "Open Inbox",
      "locatorStrategy": "XPATH",
      "locatorValue": "//a[contains(@href,'/cnd/inbox')]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 3000
    },

    {
      "stepName": "Enter Application Number",
      "locatorStrategy": "XPATH",
      "locatorValue": "(//input[@type='text'])[1]",
      "action": "TYPE_FROM_STORE",
      "inputValue": "APPLICATION_NO",
      "dynamicSleep": 1000
    },

    {
      "stepName": "Click Search",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[normalize-space()='Search']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 2000
    },

    {
      "stepName": "Open Application",
      "locatorStrategy": "XPATH",
      "locatorValue": "//table//a[1]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 3000
    },

    {
      "stepName": "Take Action First",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[.//header[normalize-space()='TAKE ACTION']]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 1000
    },

    {
      "stepName": "Assign Vehicle First",
      "locatorStrategy": "XPATH",
      "locatorValue": "//p[normalize-space()='Assign Vehicle']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 1000
    },

    {
      "stepName": "Cancel Popup",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(@class,'selector-button-border')]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 2000
    },

    {
      "stepName": "Take Action Second",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[.//header[normalize-space()='TAKE ACTION']]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 1000
    },

    {
      "stepName": "Assign Vehicle Second",
      "locatorStrategy": "XPATH",
      "locatorValue": "//p[normalize-space()='Assign Vehicle']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 1000
    },

    {
      "stepName": "Select Vehicle",
      "locatorStrategy": "CSS",
      "locatorValue": "div.select svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "0:0",
      "dynamicSleep": 1000
    },

    {
      "stepName": "Enter Vehicle Number",
      "locatorStrategy": "XPATH",
      "locatorValue": "//input[@type='text']",
      "action": "TYPE",
      "inputValue": "${vehicle.number}",
      "dynamicSleep": 1000
    },

    {
      "stepName": "Enter Comment",
      "locatorStrategy": "NAME",
      "locatorValue": "comments",
      "action": "TYPE",
      "inputValue": "${comment.assign}",
      "dynamicSleep": 1000
    },

    {
      "stepName": "Submit Vehicle Assignment",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[normalize-space()='SUBMIT']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 5000
    }

  ]
}