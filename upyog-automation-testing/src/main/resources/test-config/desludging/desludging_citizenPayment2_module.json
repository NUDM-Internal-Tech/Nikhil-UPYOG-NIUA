{
  "moduleName": "desludging_citizenPayment_module",
  "description": "Desludging citizen payment workflow",
  "baseUrl": "${selected.url}",
  "instructions": [

    {
      "stepName": "Open Desludging module",
      "locatorStrategy": "XPATH",
      "locatorValue": "//a[@href='/upyog-ui/citizen/fsm-home']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 2000
    },
    {
      "stepName": "Open View application",
      "locatorStrategy": "XPATH",
      "locatorValue": "//a[@href='/upyog-ui/citizen/fsm/my-applications']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 2000
    },
    {
      "stepName": "Open First Application View",
      "locatorStrategy": "XPATH",
      "locatorValue": "(//button[contains(.,'View')])[1]",
      "action": "CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName": "Make Payment",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(@class,'submit-bar')]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 1500
    },
    {
      "stepName": "Click Proceed To Pay",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(translate(.,'ABCDEFGHIJKLMNOPQRSTUVWXYZ','abcdefghijklmnopqrstuvwxyz'),'proceed to pay')]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 3000
    },
    {
      "stepName": "Select ICICI",
      "locatorStrategy": "XPATH",
      "locatorValue":"//label[normalize-space()='ICICI']/preceding-sibling::span/input[@type='radio']",
      "action": "CLICK_JS",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Click UPYOG Pay",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(@class,'submit-bar') and .//header[normalize-space()='Pay']]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 4000
    },
    {
      "stepName": "Open Cards Section",
      "locatorStrategy": "ID",
      "locatorValue": "nbAccordionBtn",
      "action": "CLICK",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Select Test Bank",
      "locatorStrategy": "XPATH",
      "locatorValue": "//input[@type='radio' and @value='Test Bank']",
      "action": "CLICK_JS",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Click Pay Now",
      "locatorStrategy": "ID",
      "locatorValue": "paytBtn1",
      "action": "CLICK",
      "dynamicSleep": 3000
    },
    {
      "stepName": "Enter OTP",
      "locatorStrategy": "ID",
      "locatorValue": "otp",
      "action": "TYPE",
      "inputValue": "123456",
      "dynamicSleep": 500
    },
    {
      "stepName": "Verify OTP",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[@onclick='cardsubmit()']",
      "action": "CLICK_JS",
      "dynamicSleep": 5000
    },
    {
      "stepName": "Accept Transaction Alert",
      "action": "ACCEPT_ALERT",
      "dynamicSleep": 1000
    }
  ]
}