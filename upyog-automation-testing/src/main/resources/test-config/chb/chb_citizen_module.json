{
  "moduleName": "chb_citizen_module",
  "description": "Community hall booking full citizen flow with payment",

  "baseUrl": "${selected.url}",

  "instructions": [


    {
      "stepName": "Open CHB Home",
      "locatorStrategy": "XPATH",
      "locatorValue": "//a[@href='/upyog-ui/citizen/chb-home']",
      "action": "CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName": "Open Search Hall",
      "locatorStrategy": "XPATH",
      "locatorValue": "//a[@href='/upyog-ui/citizen/chb/bookHall']",
      "action": "CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName": "Select Venue Type",
      "locatorStrategy": "CSS",
      "locatorValue": "div.select svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "0:0",
      "dynamicSleep": 2000
    },
    {
      "stepName": "Select Venue Name",
      "locatorStrategy": "CSS",
      "locatorValue": "div.select svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "1:0",
      "dynamicSleep": 2000
    },
    {
      "stepName": "Select Venue Codes *",
      "locatorStrategy": "CSS",
      "locatorValue": "div.select svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "2:0",
      "dynamicSleep": 2000
    },
    {
      "stepName": "Open Calendar",
      "locatorStrategy": "CSS",
      "locatorValue": "svg.date-range-calendar-icon",
      "action": "CLICK",
      "dynamicSleep": 1500
    },
    {
      "stepName": "Select Booking Dates",
      "action": "SELECT_DATE_RANGE",
      "inputValue": "1",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Select Venue Slots",
      "locatorStrategy": "CSS",
      "locatorValue": "div.select svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "3:0",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Search Hall",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[.//header[contains(text(),'Search')]]",
      "action": "CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName": "Select First Site Only",
      "locatorStrategy": "XPATH",
      "locatorValue": "(//input[@type='checkbox'])[2]",
      "action": "CLICK",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Click Book",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(.,'Book')]",
      "action": "CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName": "Fill New Details",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[normalize-space()='Fill New Details']",
      "action": "CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName": "Info Page Next",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(.,'Next')]",
      "action": "CLICK_JS",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Applicant Name",
      "locatorStrategy": "NAME",
      "locatorValue": "applicantName",
      "action": "TYPE",
      "inputValue": "${applicant.name}",
      "dynamicSleep": 500
    },
    {
      "stepName": "Applicant Email",
      "locatorStrategy": "NAME",
      "locatorValue": "emailId",
      "action": "TYPE",
      "inputValue": "${applicant.email}",
      "dynamicSleep": 500
    },
    {
      "stepName": "Applicant Mobile",
      "locatorStrategy": "NAME",
      "locatorValue": "mobileNumber",
      "action": "TYPE",
      "inputValue": "${mobile.number}",
      "dynamicSleep": 500
    },
    {
      "stepName": "Applicant Next",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(@class,'submit-bar')]",
      "action": "CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName": "Select Hall Category",
      "locatorStrategy": "CSS",
      "locatorValue": "div.select svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "0:0",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Select Purpose",
      "locatorStrategy": "CSS",
      "locatorValue": "div.select svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "1:1",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Purpose Description",
      "locatorStrategy": "CSS",
      "locatorValue": "textarea.card-textarea",
      "action": "TYPE",
      "inputValue": "${purpose.description}",
      "dynamicSleep": 500
    },
    {
      "stepName": "Additional Details Next",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[.//header[text()='Next']]",
      "action": "CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName": "Pincode",
      "locatorStrategy": "NAME",
      "locatorValue": "pincode",
      "action": "TYPE",
      "inputValue": "${address.pincode}",
      "dynamicSleep": 500
    },
    {
      "stepName": "Street Name",
      "locatorStrategy": "NAME",
      "locatorValue": "streetName",
      "action": "TYPE",
      "inputValue": "${street.name}",
      "dynamicSleep": 500
    },
    {
      "stepName": "House Number",
      "locatorStrategy": "NAME",
      "locatorValue": "houseNo",
      "action": "TYPE",
      "inputValue": "${house.number}",
      "dynamicSleep": 500
    },
    {
      "stepName": "Landmark",
      "locatorStrategy": "CSS",
      "locatorValue": "textarea.card-textarea",
      "action": "TYPE",
      "inputValue": "${address.landmark}",
      "dynamicSleep": 500
    },
    {
      "stepName": "Address Next",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[.//header[text()='Next']]",
      "action": "CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName": "Account Number",
      "locatorStrategy": "NAME",
      "locatorValue": "accountNumber",
      "action": "TYPE",
      "inputValue": "${account.number}",
      "dynamicSleep": 500
    },
    {
      "stepName": "Confirm Account Number",
      "locatorStrategy": "NAME",
      "locatorValue": "confirmAccountNumber",
      "action": "TYPE",
      "inputValue": "${account.number}",
      "dynamicSleep": 500
    },
    {
      "stepName": "IFSC Code",
      "locatorStrategy": "NAME",
      "locatorValue": "ifscCode",
      "action": "TYPE",
      "inputValue": "${ifsc.code}",
      "dynamicSleep": 500
    },
    {
      "stepName": "Account Holder",
      "locatorStrategy": "NAME",
      "locatorValue": "accountHolderName",
      "action": "TYPE",
      "inputValue": "${applicant.name}",
      "dynamicSleep": 500
    },
    {
      "stepName": "Bank Next",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[.//header[text()='Next']]",
      "action": "CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName": "Select Bank Proof Type",
      "locatorStrategy": "CSS",
      "locatorValue": "div.select svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "0:0",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Upload Bank Proof",
      "locatorStrategy": "XPATH",
      "locatorValue": "(//input[@type='file'])[1]",
      "action": "UPLOAD_FILE",
      "inputValue": "${document.common.proof}",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Select Address Proof Type",
      "locatorStrategy": "CSS",
      "locatorValue": "div.select svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "1:0",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Upload Address Proof",
      "locatorStrategy": "XPATH",
      "locatorValue": "(//input[@type='file'])[2]",
      "action": "UPLOAD_FILE",
      "inputValue": "${document.common.proof}",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Select Identity Proof Type",
      "locatorStrategy": "CSS",
      "locatorValue": "div.select svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "2:0",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Upload Identity Proof",
      "locatorStrategy": "XPATH",
      "locatorValue": "(//input[@type='file'])[3]",
      "action": "UPLOAD_FILE",
      "inputValue": "${document.common.proof}",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Documents Next",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[.//header[text()='Next']]",
      "action": "CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName": "Accept Declaration",
      "locatorStrategy": "CSS",
      "locatorValue": "input[type='checkbox']",
      "action": "CHECK_LAST_CHECKBOX",
      "dynamicSleep": 2000
    },
    {
      "stepName": "Submit Application",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[.//header[text()='Submit']]",
      "action": "CLICK_JS",
      "dynamicSleep": 3000
    },
    {
      "stepName":"Capture Application Number",
      "locatorStrategy":"XPATH",
      "locatorValue":"//*[contains(text(),'Booking No.') or contains(text(),'Application Number')]/following-sibling::*[1]",
      "action":"CAPTURE_TEXT",
      "inputValue":"APPLICATION_NO",
      "dynamicSleep":3000
    },
    {
      "stepName": "Click Make Payment",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(translate(.,'ABCDEFGHIJKLMNOPQRSTUVWXYZ','abcdefghijklmnopqrstuvwxyz'),'make payment')]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 2000
    },
    {
      "stepName": "Click Proceed To Pay",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(translate(.,'ABCDEFGHIJKLMNOPQRSTUVWXYZ','abcdefghijklmnopqrstuvwxyz'),'proceed to pay')]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 3000
    },
    {
      "stepName": "Select ICICI",
      "locatorStrategy": "XPATH",
      "locatorValue":"//label[normalize-space()='ICICI']/preceding-sibling::span/input[@type='radio']",
      "action": "CLICK_JS",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Click UPYOG Pay",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(@class,'submit-bar') and .//header[normalize-space()='Pay']]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 4000
    },
    {
      "stepName": "Open Cards Section",
      "locatorStrategy": "ID",
      "locatorValue": "nbAccordionBtn",
      "action": "CLICK",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Select Test Bank",
      "locatorStrategy": "XPATH",
      "locatorValue": "//input[@type='radio' and @value='Test Bank']",
      "action": "CLICK_JS",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Click Pay Now",
      "locatorStrategy": "ID",
      "locatorValue": "paytBtn1",
      "action": "CLICK",
      "dynamicSleep": 3000
    },
    {
      "stepName": "Enter OTP",
      "locatorStrategy": "ID",
      "locatorValue": "otp",
      "action": "TYPE",
      "inputValue": "123456",
      "dynamicSleep": 500
    },
    {
      "stepName": "Verify OTP",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[@onclick='cardsubmit()']",
      "action": "CLICK_JS",
      "dynamicSleep": 5000
    },
    {
      "stepName": "Accept Transaction Alert",
      "action": "ACCEPT_ALERT",
      "dynamicSleep": 1000
    }
  ]
}