{
  "moduleName":"pet_citizen_module",
  "description": "Pet Registration Citizen flow",

  "baseUrl": "${selected.url}",

  "instructions":[


    {
      "stepName":"Open Pet Module",
      "locatorStrategy":"XPATH",
      "locatorValue":"//a[@href='/upyog-ui/citizen/ptr-home']",
      "action":"CLICK_JS",
      "dynamicSleep": 2000
    },

    {
      "stepName":"Click Register Pet",
      "locatorStrategy":"XPATH",
      "locatorValue":"//div[contains(@class,'CitizenHomeCard')]//a[text()='Register Pet']",
      "action":"CLICK_JS",
      "dynamicSleep": 2000
    },

    {
      "stepName":"Requirements Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Next')]",
      "action":"CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName":"Father Name",
      "locatorStrategy":"NAME",
      "locatorValue":"fatherName",
      "action":"TYPE",
      "inputValue":"${applicant.guardian}",
      "dynamicSleep": 2000
    },

    {
      "stepName":"Email",
      "locatorStrategy":"NAME",
      "locatorValue":"emailId",
      "action":"TYPE",
      "inputValue": "${applicant.email}",
      "dynamicSleep": 2000
    },

    {
      "stepName":"Owner Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Next')]",
      "action":"CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName":"Pet Type",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"0:0",
      "dynamicSleep": 2000
    },

    {
      "stepName":"Breed",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"1:0",
      "dynamicSleep": 2000
    },

    {
      "stepName":"Gender",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"2:0",
      "dynamicSleep": 2000
    },

    {
      "stepName":"Color",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"3:0",
      "dynamicSleep": 2000
    },


    {
      "stepName":"Birth Radio",
      "locatorStrategy":"XPATH",
      "locatorValue":"//label[normalize-space()='Birth']/preceding-sibling::span/input[@type='radio']",
      "action":"CLICK_JS",
      "dynamicSleep": 2000
    },

    {
      "stepName":"Birth Date",
      "locatorStrategy":"NAME",
      "locatorValue":"birthDate",
      "action":"TYPE",
      "inputValue":"${pet.birth.date}",
      "dynamicSleep": 2000
    },

    {
      "stepName":"Pet Name",
      "locatorStrategy":"NAME",
      "locatorValue":"petName",
      "action":"TYPE",
      "inputValue":"${pet.name}",
      "dynamicSleep": 2000
    },

    {
      "stepName":"Identification Mark",
      "locatorStrategy":"NAME",
      "locatorValue":"identificationMark",
      "action":"TYPE",
      "inputValue":"${pet.identification}",
      "dynamicSleep": 2000
    },

    {
      "stepName":"Doctor Name",
      "locatorStrategy":"NAME",
      "locatorValue":"doctorName",
      "action":"TYPE",
      "inputValue":"${doctor.name}",
      "dynamicSleep": 2000
    },

    {
      "stepName":"Clinic Name",
      "locatorStrategy":"NAME",
      "locatorValue":"clinicName",
      "action":"TYPE",
      "inputValue":"${clinic.name}",
      "dynamicSleep": 2000
    },

    {
      "stepName":"Vaccination Date",
      "locatorStrategy":"NAME",
      "locatorValue":"lastVaccineDate",
      "action":"TYPE",
      "inputValue":"${vaccination.date}",
      "dynamicSleep": 2000
    },

    {
      "stepName":"Vaccination Number",
      "locatorStrategy":"NAME",
      "locatorValue":"vaccinationNumber",
      "action":"TYPE",
      "inputValue":"${vaccination.number}",
      "dynamicSleep": 2000
    },

    {
      "stepName":"Pet Next",
      "locatorStrategy":"CSS",
      "locatorValue":"button[type='submit']",
      "action":"CLICK",
      "dynamicSleep": 2000
    },




    {
      "stepName":"Property ID",
      "locatorStrategy":"NAME",
      "locatorValue":"propertyId",
      "action":"TYPE",
      "inputValue":"${property.id}",
      "dynamicSleep": 2000
    },


    {
      "stepName":"Door Number",
      "locatorStrategy":"XPATH",
      "locatorValue":"//h2[contains(.,'Door No./House No.')]/following::input[1]",
      "action":"TYPE",
      "inputValue":"${house.number}",
      "dynamicSleep": 2000
    },
    {
      "stepName":"House Name",
      "locatorStrategy":"NAME",
      "locatorValue":"houseName",
      "action":"TYPE",
      "inputValue":"${house.name}",
      "dynamicSleep": 2000
    },

    {
      "stepName":"Street Name",
      "locatorStrategy":"NAME",
      "locatorValue":"streetName",
      "action":"TYPE",
      "inputValue":"${street.name}",
      "dynamicSleep": 2000
    },

    {
      "stepName":"Address Line 1",
      "locatorStrategy":"NAME",
      "locatorValue":"addressline1",
      "action":"TYPE",
      "inputValue":"${address.line1}",
      "dynamicSleep": 2000
    },

    {
      "stepName":"Address Line 2",
      "locatorStrategy":"NAME",
      "locatorValue":"addressline2",
      "action":"TYPE",
      "inputValue":"${address.line2}",
      "dynamicSleep": 2000
    },

    {
      "stepName":"Landmark",
      "locatorStrategy":"NAME",
      "locatorValue":"landmark",
      "action":"TYPE",
      "inputValue":"${address.landmark}",
      "dynamicSleep": 2000
    },
    {
      "stepName": "City",
      "locatorStrategy": "CSS",
      "locatorValue": "div.select svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "0:0",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Locality",
      "locatorStrategy": "CSS",
      "locatorValue": "div.select svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "1:1",
      "dynamicSleep": 1000
    },
    {
      "stepName":"Pincode",
      "locatorStrategy":"NAME",
      "locatorValue":"pincode",
      "action":"TYPE",
      "inputValue":"${address.pincode}",
      "dynamicSleep": 2000
    },
    {
      "stepName":"Address Next",
      "locatorStrategy":"CSS",
      "locatorValue":"button[type='submit']",
      "action":"CLICK",
      "dynamicSleep": 2000
    },
    {
      "stepName":"Identity Proof Type",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"0:0",
      "dynamicSleep": 2000
    },

    {
      "stepName":"Upload Identity Proof",
      "locatorStrategy":"XPATH",
      "locatorValue":"(//input[@type='file'])[1]",
      "action":"UPLOAD_FILE",
      "inputValue":"${document.common.proof}",
      "dynamicSleep": 2000
    },

    {
      "stepName":"Upload Owner Proof",
      "locatorStrategy":"XPATH",
      "locatorValue":"(//input[@type='file'])[2]",
      "action":"UPLOAD_FILE",
      "inputValue":"${document.common.proof}",
      "dynamicSleep": 2000
    },

    {
      "stepName":"Upload Vaccination",
      "locatorStrategy":"XPATH",
      "locatorValue":"(//input[@type='file'])[3]",
      "action":"UPLOAD_FILE",
      "inputValue":"${document.common.proof}",
      "dynamicSleep": 2000
    },
    {
      "stepName":"Upload Fitness",
      "locatorStrategy":"XPATH",
      "locatorValue":"(//input[@type='file'])[4]",
      "action":"UPLOAD_FILE",
      "inputValue":"${document.common.proof}",
      "dynamicSleep": 2000
    },
    {
      "stepName":"Upload Pet Photo",
      "locatorStrategy":"XPATH",
      "locatorValue":"(//input[@type='file'])[5]",
      "action":"UPLOAD_FILE",
      "inputValue":"${document.common.proof}",
      "dynamicSleep": 2000
    },
    {
      "stepName":"Documents Next",
      "locatorStrategy":"CSS",
      "locatorValue":"button[type='submit']",
      "action":"CLICK",
      "dynamicSleep": 2000
    },




    {
      "stepName":"Accept Declaration",
      "locatorStrategy":"CSS",
      "locatorValue":"input[type='checkbox'][value^='I declare']",
      "action":"CLICK_JS",
      "dynamicSleep": 2000
    },

    {
      "stepName":"Submit Application",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Submit')]",
      "action":"CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName":"Capture Application Number",
      "locatorStrategy":"XPATH",
      "locatorValue":"//*[contains(text(),'Application No') or contains(text(),'Application Number')]/following-sibling::*[1]",
      "action":"CAPTURE_TEXT",
      "inputValue":"APPLICATION_NO",
      "dynamicSleep":3000
    }
  ]
}