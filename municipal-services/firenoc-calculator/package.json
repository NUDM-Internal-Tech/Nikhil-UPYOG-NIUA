{
  "name": "egov-firenoc-calculator",
  "version": "2.0.0",
  "private": true,
  "description": "Starter project for an ES6 RESTful Express API",
  "main": "dist",
  "scripts": {
    "dev": "cross-env NODE_ENV=development nodemon -w src --exec \"babel-node src\"",
    "build": "babel src -s -D -d dist",
    "start": "cross-env NODE_ENV=production node dist",
    "prestart": "npm run -s build",
    "test": "eslint src",
    "prod:start": "cross-env NODE_ENV=production node dist"
  },
  "eslintConfig": {
    "extends": "eslint:recommended",
    "parserOptions": {
      "ecmaVersion": 2022,
      "sourceType": "module"
    },
    "env": {
      "es2022": true,
      "node": true
    },
    "rules": {
      "no-console": 0,
      "no-unused-vars": 1
    }
  },
  "dependencies": {
    "ajv": "^6.10.0",
    "axios": "^1.6.0",
    "body-parser": "^1.13.3",
    "compression": "^1.5.2",
    "cors": "^2.7.1",
    "cross-env": "^7.0.0",
    "dotenv": "^6.1.0",
    "express": "^4.13.3",
    "express-async-handler": "^1.1.4",
    "kafkajs": "^2.2.4",
    "morgan": "^1.8.0",
    "pg": "^8.11.0",
    "resource-router-middleware": "^0.6.0",
    "swagger-ui-express": "^4.0.2",
    "uuid": "^9.0.0",
    "winston": "^3.2.1",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@babel/cli": "^7.23.0",
    "@babel/core": "^7.23.0",
    "@babel/node": "^7.22.0",
    "@babel/plugin-transform-runtime": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/runtime": "^7.23.0",
    "eslint": "^8.0.0",
    "nodemon": "^3.0.0"
  }
}

